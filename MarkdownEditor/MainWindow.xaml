<Window x:Class="MarkdownEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:models="clr-namespace:MarkdownEditor.Models"
        Title="{Binding WindowTitle}"
        Style="{StaticResource MainWindowStyle}"
        Height="750" Width="1280"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver" Icon="/Resources/app.png">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding OpenFolderCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}" />
        <KeyBinding Gesture="Ctrl+P" Command="{Binding TogglePreviewCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="Auto" />
            <!-- Main content -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  Toolbar                                                -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <!-- App title on the left -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✦"
                               FontSize="18"
                               Foreground="{StaticResource MauveBrush}"
                               VerticalAlignment="Center"
                               Margin="4,0,8,0" />
                    <TextBlock Text="Markdown Editor"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"
                               Opacity="0.85" />
                </StackPanel>

                <!-- Toolbar buttons on the right -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding NewFileCommand}"
                            ToolTip="New File (Ctrl+N)"
                            Content="📄 New" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenFileCommand}"
                            ToolTip="Open File (Ctrl+O)"
                            Content="📂 Open File"
                            Margin="2,0" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenFolderCommand}"
                            ToolTip="Open Folder (Ctrl+Shift+O)"
                            Content="📁 Open Folder"
                            Margin="2,0" />
                    <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="6,4" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding SaveCommand}"
                            ToolTip="Save (Ctrl+S)"
                            Content="💾 Save" />
                    <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="6,4" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding TogglePreviewCommand}"
                            ToolTip="Toggle Preview (Ctrl+P)"
                            Content="{Binding ViewModeLabel}" />
                </StackPanel>

                <!-- Spacer -->
                <Border />
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  Main Content Area                                      -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- File tree panel -->
                <ColumnDefinition Width="240" MinWidth="160" MaxWidth="500" />
                <ColumnDefinition Width="1" />
                <!-- Editor -->
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="1" />
                <!-- Outline sidebar -->
                <ColumnDefinition Width="260" MinWidth="160" MaxWidth="500" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  LEFT: File Tree                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource MantleBrush}">
                <DockPanel>
                    <!-- File tree header -->
                    <Border DockPanel.Dock="Top"
                            Padding="12,10"
                            BorderBrush="{StaticResource Surface0Brush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource ToolbarButton}"
                                    Command="{Binding RefreshTreeCommand}"
                                    ToolTip="Refresh"
                                    Content="↻"
                                    FontSize="14"
                                    Padding="6,2" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="E X P L O R E R"
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Overlay0Brush}" />
                                <TextBlock Text="{Binding RootFolderName}"
                                           FontSize="12"
                                           Foreground="{StaticResource SubtextBrush}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- File tree content -->
                    <TreeView x:Name="FileTreeView"
                              ItemsSource="{Binding FileTree}"
                              Padding="4,6"
                              SelectedItemChanged="FileTreeView_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2,1">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMarkdown}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="1" />

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  CENTER: Editor                                     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="2" Background="{StaticResource BaseBrush}">
                <DockPanel>
                    <!-- Editor tab bar -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource MantleBrush}"
                            BorderBrush="{StaticResource Surface0Brush}"
                            BorderThickness="0,0,0,1"
                            Padding="0"
                            Height="38">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                            <!-- Active file tab -->
                            <Border x:Name="FileTab"
                                    Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="{StaticResource BaseBrush}"
                                    BorderBrush="{StaticResource MauveBrush}"
                                    BorderThickness="0,2,0,0"
                                    Padding="16,0"
                                    Margin="0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📝"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="{Binding CurrentFileName}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text=" •"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource MauveBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Editor area -->
                    <Grid>
                        <!-- Welcome screen (when no file is open) -->
                        <StackPanel x:Name="WelcomePanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding IsFileOpen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <TextBlock Text="✦"
                                       FontSize="48"
                                       Foreground="{StaticResource MauveBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"
                                       Opacity="0.6" />
                            <TextBlock Text="Markdown Editor"
                                       FontSize="24"
                                       FontWeight="Light"
                                       Foreground="{StaticResource TextBrush}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.7" />
                            <TextBlock Text="Open a file or folder to get started"
                                       FontSize="13"
                                       Foreground="{StaticResource Overlay0Brush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,24" />
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="11.5"
                                           VerticalAlignment="Center">
                                    <Run Text="Ctrl+O" Foreground="{StaticResource BlueBrush}" />
                                    <Run Text=" Open File   " />
                                    <Run Text="Ctrl+Shift+O" Foreground="{StaticResource BlueBrush}" />
                                    <Run Text=" Open Folder   " />
                                    <Run Text="Ctrl+P" Foreground="{StaticResource BlueBrush}" />
                                    <Run Text=" Preview" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Editor + Preview split -->
                        <Grid x:Name="EditorPreviewGrid"
                              Visibility="{Binding IsFileOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                                <ColumnDefinition x:Name="PreviewSplitterColumn" Width="0" />
                                <ColumnDefinition x:Name="PreviewColumn" Width="0" />
                            </Grid.ColumnDefinitions>

                            <!-- AvalonEdit Editor -->
                            <avalonEdit:TextEditor
                                x:Name="MarkdownTextEditor"
                                Grid.Column="0"
                                Visibility="{Binding IsEditorVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource BaseBrush}"
                                Foreground="{StaticResource TextBrush}"
                                FontFamily="Cascadia Code, Consolas, Courier New"
                                FontSize="14"
                                LineNumbersForeground="{StaticResource Overlay0Brush}"
                                ShowLineNumbers="True"
                                WordWrap="True"
                                Padding="8,8"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                BorderThickness="0" />

                            <!-- Preview splitter -->
                            <GridSplitter Grid.Column="1" Width="1"
                                          Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!-- WebView2 Preview -->
                            <Border Grid.Column="2"
                                    Background="{StaticResource BaseBrush}"
                                    Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <wv2:WebView2 x:Name="PreviewWebView"
                                              DefaultBackgroundColor="#1E1E2E" />
                            </Border>
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3" Width="1" />

            <!-- ═══════════════════════════════════════════════════ -->
            <!--  RIGHT: Document Outline Sidebar                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Grid.Column="4"
                    Background="{StaticResource MantleBrush}">
                <DockPanel>
                    <!-- Outline header -->
                    <Border DockPanel.Dock="Top"
                            Padding="12,10"
                            BorderBrush="{StaticResource Surface0Brush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="O U T L I N E"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Overlay0Brush}" />
                    </Border>

                    <!-- Outline tree -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4,6">
                        <ItemsControl ItemsSource="{Binding OutlineItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:OutlineItem}">
                                    <StackPanel>
                                        <!-- This heading item -->
                                        <Border x:Name="OutlineBd"
                                                CornerRadius="4"
                                                Padding="8,5"
                                                Margin="{Binding IndentMargin, Converter={StaticResource IndentConverter}}"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="OutlineItem_Click"
                                                Tag="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="LevelIndicator"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"
                                                           Opacity="0.6" />
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12.5"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Child headings (recursive) -->
                                        <ItemsControl ItemsSource="{Binding Children}"
                                                      Margin="0,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:OutlineItem}">
                                                    <StackPanel>
                                                        <Border x:Name="ChildBd"
                                                                CornerRadius="4"
                                                                Padding="8,4"
                                                                Margin="{Binding IndentMargin, Converter={StaticResource IndentConverter}}"
                                                                Cursor="Hand"
                                                                MouseLeftButtonUp="OutlineItem_Click"
                                                                Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontSize="9"
                                                                           FontWeight="Bold"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0"
                                                                           Opacity="0.5"
                                                                           Foreground="{StaticResource Overlay0Brush}" />
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource SubtextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Level 3 children -->
                                                        <ItemsControl ItemsSource="{Binding Children}" Margin="0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type models:OutlineItem}">
                                                                    <Border CornerRadius="4"
                                                                            Padding="8,3"
                                                                            Margin="{Binding IndentMargin, Converter={StaticResource IndentConverter}}"
                                                                            Cursor="Hand"
                                                                            MouseLeftButtonUp="OutlineItem_Click"
                                                                            Tag="{Binding}">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   FontSize="11.5"
                                                                                   Foreground="{StaticResource Overlay1Brush}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  Status Bar                                             -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           Foreground="{StaticResource Overlay0Brush}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="CursorPositionText"
                               FontSize="11"
                               Foreground="{StaticResource Overlay0Brush}"
                               Margin="0,0,16,0" />
                    <TextBlock Text="Markdown"
                               FontSize="11"
                               Foreground="{StaticResource BlueBrush}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
